# Copy to .env and adjust values
# cp .env.example .env

DEBUG=True
SECRET_KEY=your-secret-key-here-minimum-50-characters-long-random-string

# Database (SQLite default if unset)
DATABASE_URL=sqlite:///db.sqlite3
# DATABASE_URL=postgres://user:password@localhost:5432/vasavi_db

ALLOWED_HOSTS=localhost,127.0.0.1

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_CURRENCY=INR

SMS_BACKEND=utils.sms.ConsoleSMSBackend
SMS_API_KEY=
SMS_SENDER_ID=VASAVI
SMS_API_URL=

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

ADMIN_URL=admin/

DJANGO_SETTINGS_MODULE=config.settings.development

OTP_LOG_RETENTION_DAYS=30
DEFAULT_FROM_EMAIL=noreply@vasavi.example
BOOKING_NOTIFICATION_EMAIL=noreply@vasavi.example
SMS_PROVIDER_ENABLED=False
DONOR_EXPORT_RETENTION_DAYS=7
BOOKING_EXPORT_RETENTION_DAYS=7

IDEMPOTENCY_KEY_REQUIRED=True
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_RETRY_AFTER_SECONDS=2

# Auth cookies (set automatically by the backend — do not configure manually)
# Customer app (vasavi-main-site): vasavi_refresh (path: /api/v1/accounts/ via default /)
# Staff app (vasavi-role-portal):    vasavi_staff_refresh (path: /api/v1/staff/)

# Production only
# SECURE_SSL_REDIRECT=True
# DJANGO_LOG_LEVEL=WARNING
